# ==============================================================================
# Distributed Lottery System Environment Variables Template
# Copy this file to '.env' and modify values to match your environments.
# ==============================================================================

# 1. Database Configuration (PostgreSQL)
DB_HOST=lottery-postgres
DB_PORT=5432
DB_NAME=lottery
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Database Connection Pool (HikariCP)
HIKARI_MINIMUM_IDLE=5
HIKARI_MAXIMUM_POOL_SIZE=20
HIKARI_IDLE_TIMEOUT=30000
HIKARI_CONNECTION_TIMEOUT=20000
HIKARI_MAX_LIFETIME=1800000

# 2. Redis Configuration
REDIS_HOST=lottery-redis
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=

# 3. RabbitMQ Configuration
RABBITMQ_HOST=lottery-rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# 4. Security & Core API Configurations
JWT_SECRET=dGhpc2lzYW5leHRyZW1lbHlzZWN1cmVzcmluZ2Jvb3Rqd3RzaGFyZWRzZWNyZXRrZXlmb3Jsb3R0ZXJ5c3lzdGVt
JWT_EXPIRATION_MS=3600000
RATE_LIMIT_LIMIT=3
RATE_LIMIT_DURATION=60
