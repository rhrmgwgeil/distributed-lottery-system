<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Properties>
        <!-- Standard file logging pattern with UTC offset -->
        <Property name="LOG_PATTERN">%d{yyyy-MM-dd HH:mm:ss.SSS XXX} [%t] %-5level %logger{36} - %msg%n%style{%throwable}{red}</Property>
        <!-- Colored console logging pattern -->
        <Property name="CONSOLE_PATTERN">%style{%d{yyyy-MM-dd HH:mm:ss.SSS XXX}}{cyan} %highlight{[%t]}{FATAL=red, ERROR=red, WARN=yellow, INFO=green, DEBUG=blue} %highlight{%-5level}{FATAL=red, ERROR=red, WARN=yellow, INFO=green, DEBUG=blue} %style{%logger{36}}{magenta} - %msg%n%style{%throwable}{red}</Property>
        <Property name="LOG_FILE_PATH">logs</Property>
        <Property name="LOG_FILE_NAME">app.log</Property>
    </Properties>

    <Appenders>
        <!-- Console Appender -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${CONSOLE_PATTERN}" />
        </Console>

        <!-- Rolling File Appender -->
        <RollingFile name="RollingFile" 
                     fileName="${LOG_FILE_PATH}/${LOG_FILE_NAME}"
                     filePattern="${LOG_FILE_PATH}/archive/app-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${LOG_PATTERN}" />
            <Policies>
                <!-- Rollover daily -->
                <TimeBasedTriggeringPolicy interval="1" modulate="true" />
                <!-- Rollover if file exceeds 10MB -->
                <SizeBasedTriggeringPolicy size="10 MB" />
            </Policies>
            <!-- Retain up to 30 historical log files -->
            <DefaultRolloverStrategy max="30" />
        </RollingFile>
    </Appenders>

    <Loggers>
        <!-- Application Logger (Detailed debug for com.lottery.system) -->
        <Logger name="com.lottery.system" level="DEBUG" additivity="false">
            <AppenderRef ref="Console" />
            <AppenderRef ref="RollingFile" />
        </Logger>

        <!-- Spring Framework Logger -->
        <Logger name="org.springframework" level="INFO" additivity="false">
            <AppenderRef ref="Console" />
            <AppenderRef ref="RollingFile" />
        </Logger>

        <!-- Hibernate Logger -->
        <Logger name="org.hibernate" level="INFO" additivity="false">
            <AppenderRef ref="Console" />
            <AppenderRef ref="RollingFile" />
        </Logger>

        <!-- Root Logger -->
        <Root level="INFO">
            <AppenderRef ref="Console" />
            <AppenderRef ref="RollingFile" />
        </Root>
    </Loggers>
</Configuration>
